# Interviewer Agent Configuration

# ===== LLM API Keys =====
# Get Grok API key from https://console.x.ai/
XAI_API_KEY=your_grok_api_key_here

# Get Gemini API key from https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=your_gemini_api_key_here

# Choose which LLM to use: 'grok' or 'gemini' (default: 'gemini')
LLM_PROVIDER=gemini

# ===== Server Configuration =====
PORT=4000
NODE_ENV=development

# ===== Feature Flags =====
# Enable LLM-based questions and evaluation (true/false)
USE_LLM=true

# Fallback to heuristic mode if LLM fails (true/false)
FALLBACK_TO_HEURISTIC=true
